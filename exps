#include <stdio.h>
#include <stdbool.h>

int main() {
    int n = 5; // processes
    int m = 3; // resources

    int alloc[5][3] = {
        {0, 1, 0},
        {2, 0, 0},
        {3, 0, 2},
        {2, 1, 1},
        {0, 0, 2}
    };

    int max[5][3] = {
        {7, 5, 3},
        {3, 2, 2},
        {9, 0, 2},
        {2, 2, 2},
        {4, 3, 3}
    };

    int avail[3] = {3, 3, 2};
    int need[5][3];
    int finish[5] = {0};
    int safeSeq[5];
    int index = 0;

    // Calculate NEED matrix
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            need[i][j] = max[i][j] - alloc[i][j];
        }
    }

    // Print NEED matrix (optional but useful)
    printf("Need Matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            printf("%d ", need[i][j]);
        }
        printf("\n");
    }

    // Safety Algorithm
    int count = 0;
    while (count < n) {
        int found = 0;

        for (int i = 0; i < n; i++) {
            if (finish[i] == 0) {
                int flag = 0;

                for (int j = 0; j < m; j++) {
                    if (need[i][j] > avail[j]) {
                        flag = 1;
                        break;
                    }
                }

                if (flag == 0) {
                    // Process can execute
                    safeSeq[index++] = i;

                    for (int j = 0; j < m; j++) {
                        avail[j] += alloc[i][j];
                    }

                    finish[i] = 1;
                    found = 1;
                    count++;
                }
            }
        }

        // If no process was found in this pass → unsafe
        if (found == 0) {
            printf("\nSystem is NOT in a safe state\n");
            return 0;
        }
    }

    // If all processes finished
    printf("\nSystem is in a SAFE state\n");
    printf("Safe sequence: ");
    for (int i = 0; i < n; i++) {
        printf("P%d", safeSeq[i]);
        if (i != n - 1)
            printf(" -> ");
    }
    printf("\n");

    return 0;
}

