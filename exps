#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
sem_t empty, full;
int bu er = 0;
void* producer(void* arg) {
sem_wait(&empty);
bu er++;
printf("Produced: %d\n", bu er);
sem_post(&full);
}
void* consumer(void* arg) {
sem_wait(&full);
printf("Consumed: %d\n", bu er);
bu er--;
sem_post(&empty);
}
int main() {
pthread_t p, c;
sem_init(&empty, 0, 1);
sem_init(&full, 0, 0);
pthread_create(&p, NULL, producer, NULL);
pthread_create(&c, NULL, consumer, NULL);
pthread_join(p, NULL);
pthread_join(c, NULL);
return 0;
}
