#include <stdio.h>

int main() {
    int n, f, i, j = 0, k, avail, count = 0;
    int pages[50], frames[10];

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter the page reference string: ");
    for (i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &f);

    // Initialize frames as empty
    for (i = 0; i < f; i++)
        frames[i] = -1;

    printf("\nRef String\tFrames\n");

    for (i = 0; i < n; i++) {
        printf("%d\t\t", pages[i]);
        avail = 0;

        // Check for page hit
        for (k = 0; k < f; k++) {
            if (frames[k] == pages[i]) {
                avail = 1;
                break;
            }
        }

        // Page fault
        if (avail == 0) {
            frames[j] = pages[i];
            j = (j + 1) % f; // FIFO replacement
            count++;

            for (k = 0; k < f; k++) {
                if (frames[k] != -1)
                    printf("%d ", frames[k]);
                else
                    printf("- ");
            }
            printf("(PF)");
        }
        // Page hit
        else {
            for (k = 0; k < f; k++) {
                if (frames[k] != -1)
                    printf("%d ", frames[k]);
                else
                    printf("- ");
            }
            printf("(Hit)");
        }

        printf("\n");
    }

    printf("\nTotal Page Faults: %d\n", count);

    return 0;
}
